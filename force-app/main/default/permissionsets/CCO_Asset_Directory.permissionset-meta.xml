<?xml version="1.0" encoding="UTF-8"?>
<PermissionSet xmlns="http://soap.sforce.com/2006/04/metadata">
    <description>Full read/write access to all CCO United custom objects and fields. Assign to admins and data loaders.</description>
    <hasActivationRequired>false</hasActivationRequired>
    <label>CCO Asset Directory</label>

    <!-- Apex class access -->
    <classAccesses>
        <apexClass>CCOAssetDirectoryController</apexClass>
        <enabled>true</enabled>
    </classAccesses>

    <!-- Object permissions -->
    <objectPermissions>
        <allowCreate>true</allowCreate>
        <allowDelete>true</allowDelete>
        <allowEdit>true</allowEdit>
        <allowRead>true</allowRead>
        <modifyAllRecords>true</modifyAllRecords>
        <object>National_Organization__c</object>
        <viewAllRecords>true</viewAllRecords>
    </objectPermissions>
    <objectPermissions>
        <allowCreate>true</allowCreate>
        <allowDelete>true</allowDelete>
        <allowEdit>true</allowEdit>
        <allowRead>true</allowRead>
        <modifyAllRecords>true</modifyAllRecords>
        <object>Local_Community_Group__c</object>
        <viewAllRecords>true</viewAllRecords>
    </objectPermissions>
    <objectPermissions>
        <allowCreate>true</allowCreate>
        <allowDelete>true</allowDelete>
        <allowEdit>true</allowEdit>
        <allowRead>true</allowRead>
        <modifyAllRecords>true</modifyAllRecords>
        <object>Asset_Category__c</object>
        <viewAllRecords>true</viewAllRecords>
    </objectPermissions>
    <objectPermissions>
        <allowCreate>true</allowCreate>
        <allowDelete>true</allowDelete>
        <allowEdit>true</allowEdit>
        <allowRead>true</allowRead>
        <modifyAllRecords>true</modifyAllRecords>
        <object>Asset__c</object>
        <viewAllRecords>true</viewAllRecords>
    </objectPermissions>

    <!-- National_Organization__c fields -->
    <fieldPermissions>
        <editable>true</editable>
        <field>National_Organization__c.Description__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>true</editable>
        <field>National_Organization__c.Status__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>true</editable>
        <field>National_Organization__c.Website__c</field>
        <readable>true</readable>
    </fieldPermissions>

    <!-- Local_Community_Group__c fields -->
    <!-- National_Organization__c is a required MasterDetail — SF manages FLS automatically, cannot set here -->
    <fieldPermissions>
        <editable>true</editable>
        <field>Local_Community_Group__c.Description__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>true</editable>
        <field>Local_Community_Group__c.Location__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>true</editable>
        <field>Local_Community_Group__c.Contact_Email__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>true</editable>
        <field>Local_Community_Group__c.Status__c</field>
        <readable>true</readable>
    </fieldPermissions>

    <!-- Asset_Category__c fields -->
    <!-- Local_Community_Group__c is a required Lookup — SF manages FLS automatically, cannot set here -->
    <fieldPermissions>
        <editable>true</editable>
        <field>Asset_Category__c.Description__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>true</editable>
        <field>Asset_Category__c.Icon_Name__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>true</editable>
        <field>Asset_Category__c.Display_Order__c</field>
        <readable>true</readable>
    </fieldPermissions>

    <!-- Asset__c fields -->
    <!-- Asset_Category__c is a required Lookup — SF manages FLS automatically, cannot set here -->
    <fieldPermissions>
        <editable>true</editable>
        <field>Asset__c.Asset_Type__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>true</editable>
        <field>Asset__c.Description__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>true</editable>
        <field>Asset__c.Status__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>true</editable>
        <field>Asset__c.File_URL__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>true</editable>
        <field>Asset__c.Contact_Name__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>true</editable>
        <field>Asset__c.Contact_Email__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>true</editable>
        <field>Asset__c.Tags__c</field>
        <readable>true</readable>
    </fieldPermissions>
</PermissionSet>
